# Responders app env — copy to .env.local for local dev.
#
# Base URL of the RAPIDA Django API, INCLUDING the trailing "/api".
# The browser talks only to /api/proxy/* (same origin); next.config.ts rewrites
# that to this URL server-side, so the plain-HTTP backend never triggers
# mixed-content blocking on an HTTPS (Vercel) deployment.
#
# Local dev against the deployed backend:
RAPIDA_API_BASE=http://5.189.150.44/api
#
# On Vercel: set RAPIDA_API_BASE in Project Settings → Environment Variables
# (it is read at build time, so a redeploy is required after changing it).
